  "seo": {
    "title": "Google Play Scraper Tool for App Search Metadata",
    "description": "Search Google Play app results with Better Fetch and return app IDs, titles, developers, summaries, icons, ratings, review labels, store URLs, and monetization badges.",
    "intro": "Google Play Scraper gives agents a focused way to inspect public Google Play app search results. Provide a keyword query and the tool fetches Google Play's app search page, extracts the visible result cards, and returns normalized app IDs, titles, developers, summaries, icons, ratings, review labels, store URLs, and monetization badges.",
    "useCases": [
      {
        "title": "App market research",
        "description": "Search a keyword and capture competing Android apps with visible ratings, developers, summaries, and Google Play URLs."
      },
      {
        "title": "ASO discovery",
        "description": "Collect app IDs and result-card copy before deciding which app detail pages or reviews deserve deeper extraction."
      },
      {
        "title": "Agent briefs",
        "description": "Give an agent structured Google Play search context for a product category, brand, or feature area."
      }
    ],
    "faqs": [
      {
        "question": "Does Google Play Scraper extract reviews?",
        "answer": "No. Version 0.1 returns app search result cards only. Reviews and full app detail pages should be added as separate validated tools or future slices."
      },
      {
        "question": "Can I localize results?",
        "answer": "Yes. The tool supports Google Play language and country parameters, such as en-US with US or en-AU with AU."
      },
      {
        "question": "Does it require a Google API key?",
        "answer": "No. The tool reads public Google Play result pages through Better Fetch and does not use account-specific Google credentials."
      }
    ],
    "keywords": [
      "Google Play scraper",
      "Google Play app search",
      "Android app metadata",
      "ASO research",
      "app store scraper",
      "AI agent app research"
    ]
  },
  "popularity": {
    "rank": 19,
    "score": 2400
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "minLength": 1,
        "description": "Google Play keyword search query."
      },
      "language": {
        "type": "string",
        "default": "en-US",
        "description": "Google Play hl parameter, such as en-US or de-DE."
      },
      "country": {
        "type": "string",
        "default": "US",
        "description": "Google Play gl parameter, such as US, AU, GB, or DE."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10,
        "description": "Maximum app cards to return."
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Requested Google Play query"
      },
      "source_url": {
        "type": "string",
        "description": "Fetched Google Play search URL"
      },
      "count": {
        "type": "integer",
        "description": "Number of app cards returned"
      },
      "apps": {
        "type": "array",
        "description": "Public Google Play app result cards",
        "items": {
          "type": "object",
          "properties": {
            "app_id": {
              "type": "string",
              "description": "Google Play app package ID"
            },
            "title": {
              "type": "string",
              "description": "App title"
            },
            "developer": {
              "type": "string",
              "description": "Visible developer name"
            },
            "summary": {
              "type": "string",
              "description": "Visible result-card summary"
            },
            "url": {
              "type": "string",
              "description": "Canonical Google Play app URL"
            },
            "icon": {
              "type": "string",
              "description": "App icon URL"
            },
            "rating": {
              "type": "number",
              "description": "Visible rating value"
            },
            "rating_text": {
              "type": "string",
              "description": "Visible rating text"
            },
            "reviews_text": {
              "type": "string",
              "description": "Visible review-count label"
            },
            "contains_ads": {
              "type": "boolean",
              "description": "Whether the card says contains ads"
            },
            "in_app_purchases": {
              "type": "boolean",
              "description": "Whether the card says in-app purchases"
            }
          },
          "required": [
            "app_id",
            "title",
            "url"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "query",
      "source_url",
      "count",
      "apps"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "openai-apps",
      "input": {
        "query": "openai",
        "max_results": 3
      },
      "expect": {
        "outputMatches": {
          "apps": {
            "minLength": 1
          }
        }
      }
    }
  ],
  "entry": "src/index.ts"
}
