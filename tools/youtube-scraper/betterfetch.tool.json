{
  "name": "youtube_scraper",
  "version": "0.9.3",
  "title": "YouTube Scraper",
  "description": "Search public YouTube, inspect channels, videos, Shorts, trending Shorts, live streams, playlists, community posts, sponsors, comments, and comment replies.",
  "category": "social",
  "logo": {
    "label": "YouTube logo",
    "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 256 180\"><path fill=\"red\" d=\"M250.346 28.075A32.18 32.18 0 0 0 227.69 5.418C207.824 0 127.87 0 127.87 0S47.912.164 28.046 5.582A32.18 32.18 0 0 0 5.39 28.24c-6.009 35.298-8.34 89.084.165 122.97a32.18 32.18 0 0 0 22.656 22.657c19.866 5.418 99.822 5.418 99.822 5.418s79.955 0 99.82-5.418a32.18 32.18 0 0 0 22.657-22.657c6.338-35.348 8.291-89.1-.164-123.134Z\"/><path fill=\"#FFF\" d=\"m102.421 128.06l66.328-38.418l-66.328-38.418z\"/></svg>",
    "sourceUrl": "https://icon-sets.iconify.design/logos/youtube-icon/"
  },
  "seo": {
    "title": "YouTube Scraper for Videos, Channels, Comments and Sponsors",
    "description": "Scrape public YouTube search, channels, videos, playlists, community posts, comments, replies, and sponsor evidence into normalized agent-ready data.",
    "intro": "YouTube Scraper gives agents a focused way to collect public YouTube data without using a private account. It renders public YouTube surfaces through Better Fetch, parses page and network data, deduplicates results, and returns normalized fields that are easy to save, compare, or pass into an LLM workflow.",
    "useCases": [
      {
        "title": "Video research",
        "description": "Search YouTube for a topic and return structured video cards for market research, content planning, or source discovery."
      },
      {
        "title": "Channel monitoring",
        "description": "Inspect a public channel videos tab and capture recent titles, URLs, view counts, durations, thumbnails, and publish-time labels."
      },
      {
        "title": "Agent briefs",
        "description": "Let an agent gather public YouTube results and summarize visible metadata before deciding which videos need deeper review."
      },
      {
        "title": "Comment research",
        "description": "Collect public comments or expand a targeted parent thread into normalized replies with author, like, permalink, and continuation evidence."
      },
      {
        "title": "Trending Shorts discovery",
        "description": "Collect YouTube's current logged-out Shorts sequence with public engagement, channel, publish, duration, keyword, and thumbnail metadata."
      }
    ],
    "faqs": [
      {
        "question": "Does YouTube Scraper download video files?",
        "answer": "No. It returns public metadata from YouTube pages and does not download video media, captions, private analytics, or account-only data."
      },
      {
        "question": "Can it scrape private or age-gated videos?",
        "answer": "No. The tool is designed for public YouTube pages visible to the Better Fetch browser session without user-specific authentication."
      },
      {
        "question": "Why are view counts returned as text and numbers?",
        "answer": "YouTube often renders compact labels such as 1.2M views. The tool preserves the visible text and also returns a best-effort integer when it can parse one."
      },
      {
        "question": "Does comment collection require a YouTube login?",
        "answer": "No. video_comments and comment_replies use the public logged-out watch page and return only discussion data YouTube exposes to that browser session."
      }
    ],
    "keywords": [
      "YouTube scraper",
      "YouTube search scraper",
      "video metadata",
      "channel monitoring",
      "YouTube comments scraper",
      "YouTube agent tool",
      "public video data"
    ]
  },
  "popularity": {
    "rank": 9,
    "score": 92000
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "search",
          "channel",
          "channel_videos",
          "channel_shorts",
          "channel_lives",
          "channel_playlists",
          "channel_posts",
          "hashtag_search",
          "playlist",
          "community_post",
          "video_comments",
          "comment_replies",
          "video_sponsors",
          "trending_shorts",
          "video"
        ],
        "description": "Operation to run. If omitted, the tool infers it from query, channel_url, or video_url."
      },
      "query": {
        "type": "string",
        "description": "YouTube search query. Use either query or channel_url."
      },
      "channel_url": {
        "type": "string",
        "format": "uri",
        "description": "Public YouTube channel URL used by channel modes."
      },
      "video_url": {
        "type": "string",
        "format": "uri",
        "description": "Public YouTube watch, Shorts, youtu.be, or embed URL used by video, video_comments, comment_replies, and video_sponsors modes."
      },
      "comment_id": {
        "type": "string",
        "description": "Public parent YouTube comment id required by comment_replies mode. video_comments returns this as each comment's id."
      },
      "playlist_id": {
        "type": "string",
        "description": "Public YouTube playlist id or playlist URL. Used by playlist mode."
      },
      "hashtag": {
        "type": "string",
        "description": "Hashtag with or without the leading #. Used by hashtag_search mode."
      },
      "post_url": {
        "type": "string",
        "description": "Public youtube.com/post URL or community post id. Used by community_post mode."
      },
      "content_type": {
        "type": "string",
        "enum": ["all", "shorts"],
        "default": "all",
        "description": "Return all visible hashtag content or only Shorts."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 25,
        "default": 10,
        "description": "Maximum video cards to return"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "source": {
        "type": "string",
        "description": "Search query, channel URL, video URL, playlist id, hashtag, or post id used"
      },
      "source_url": {
        "type": "string",
        "description": "Fetched YouTube URL"
      },
      "count": {
        "type": "integer",
        "description": "Number of primary records returned for the selected mode"
      },
      "videos": {
        "type": "array",
        "description": "Public YouTube video cards",
        "items": {
          "type": "object",
          "properties": {
            "video_id": {
              "type": "string",
              "description": "YouTube video id"
            },
            "title": {
              "type": "string",
              "description": "Video title"
            },
            "url": {
              "type": "string",
              "description": "Canonical YouTube watch URL"
            },
            "channel": {
              "type": "string",
              "description": "Visible channel name"
            },
            "channel_id": {
              "type": "string",
              "description": "YouTube channel id"
            },
            "channel_url": {
              "type": "string",
              "description": "Visible channel URL"
            },
            "duration": {
              "type": "string",
              "description": "Visible duration label"
            },
            "duration_seconds": {
              "type": "number",
              "description": "Duration in seconds when YouTube exposes it"
            },
            "views_text": {
              "type": "string",
              "description": "Visible view-count label"
            },
            "view_count": {
              "type": "integer",
              "description": "Best-effort parsed view count"
            },
            "like_count": {
              "type": "integer",
              "description": "Public like count when YouTube exposes it"
            },
            "comment_count": {
              "type": "integer",
              "description": "Public comment count when YouTube exposes it"
            },
            "published": {
              "type": "string",
              "description": "Visible publish-time label"
            },
            "thumbnail": {
              "type": "string",
              "description": "Thumbnail URL"
            },
            "description": {
              "type": "string",
              "description": "Visible description snippet"
            },
            "keywords": {
              "type": "string",
              "description": "Newline-delimited public video keywords"
            }
          },
          "required": [
            "video_id",
            "title",
            "url"
          ],
          "additionalProperties": false
        }
      },
      "playlists": {
        "type": "array",
        "description": "Public channel playlists when channel_playlists mode is used",
        "items": {
          "type": "object",
          "properties": {
            "playlist_id": { "type": "string" },
            "title": { "type": "string" },
            "url": { "type": "string" },
            "video_count_text": { "type": "string" },
            "updated": { "type": "string" },
            "thumbnail": { "type": "string" }
          },
          "required": ["playlist_id", "title", "url"],
          "additionalProperties": false
        }
      },
      "channel": {
        "type": "object",
        "description": "Public channel metadata when channel mode is used",
        "properties": {
          "channel_id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "handle_url": { "type": "string" },
          "description": { "type": "string" },
          "avatar": { "type": "string" },
          "rss_url": { "type": "string" },
          "is_family_safe": { "type": "boolean" }
        },
        "required": ["channel_id", "title", "url"],
        "additionalProperties": false
      },
      "playlist": {
        "type": "object",
        "description": "Public playlist metadata when playlist mode is used",
        "properties": {
          "playlist_id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "owner_url": { "type": "string" },
          "owner_channel_id": { "type": "string" },
          "total_videos": { "type": "integer" },
          "views_text": { "type": "string" },
          "updated": { "type": "string" },
          "thumbnail": { "type": "string" }
        },
        "required": ["playlist_id", "title", "url"],
        "additionalProperties": false
      },
      "posts": {
        "type": "array",
        "description": "Public channel community posts or one community post detail",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "url": { "type": "string" },
            "channel_title": { "type": "string" },
            "channel_id": { "type": "string" },
            "channel_url": { "type": "string" },
            "content": { "type": "string" },
            "image_urls": { "type": "string" },
            "image_count": { "type": "integer" },
            "like_count_text": { "type": "string" },
            "like_count": { "type": "integer" },
            "published": { "type": "string" },
            "video_id": { "type": "string" },
            "video_title": { "type": "string" },
            "video_url": { "type": "string" },
            "video_thumbnail": { "type": "string" }
          },
          "required": ["id", "url"],
          "additionalProperties": false
        }
      },
      "comments": {
        "type": "array",
        "description": "Logged-out public comments or replies returned by video_comments and comment_replies modes",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "content": { "type": "string" },
            "url": { "type": "string" },
            "published": { "type": "string" },
            "reply_level": { "type": "integer" },
            "author_name": { "type": "string" },
            "author_channel_id": { "type": "string" },
            "author_verified": { "type": "boolean" },
            "author_creator": { "type": "boolean" },
            "author_avatar_url": { "type": "string" },
            "author_channel_url": { "type": "string" },
            "like_count_text": { "type": "string" },
            "like_count": { "type": "integer" },
            "reply_count_text": { "type": "string" },
            "reply_count": { "type": "integer" },
            "replies_continuation_token": { "type": "string" }
          },
          "required": ["id", "content", "url"],
          "additionalProperties": false
        }
      },
      "total_count": {
        "type": "integer",
        "description": "Total public comment count displayed by YouTube when video_comments mode is used"
      },
      "parent_comment_id": {
        "type": "string",
        "description": "Parent comment id expanded by comment_replies mode"
      },
      "comments_continuation_token": {
        "type": "string",
        "description": "Evidence token exposed by YouTube for another public comment or reply page; pagination is not yet executed by this tool"
      },
      "continuation_token": {
        "type": "string",
        "description": "Public continuation token when YouTube exposes another page of channel posts"
      },
      "sponsor_video": {
        "type": "object",
        "description": "Video and paid-promotion context for video_sponsors mode",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "channel": { "type": "string" },
          "channel_id": { "type": "string" },
          "channel_url": { "type": "string" },
          "is_paid_promotion": { "type": "boolean" }
        },
        "required": ["id", "url", "title", "is_paid_promotion"],
        "additionalProperties": false
      },
      "suspected_sponsors": {
        "type": "array",
        "description": "Brands inferred from explicit public description evidence",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "website": { "type": "string" },
            "confidence": { "type": "string" },
            "evidence_source": { "type": "string" },
            "evidence_text": { "type": "string" }
          },
          "required": ["name", "confidence", "evidence_source", "evidence_text"],
          "additionalProperties": false
        }
      },
      "sponsor_segments": {
        "type": "array",
        "description": "Public community sponsor/self-promotion timing segments from SponsorBlock",
        "items": {
          "type": "object",
          "properties": {
            "start_seconds": { "type": "number" },
            "end_seconds": { "type": "number" },
            "duration_seconds": { "type": "number" },
            "category": { "type": "string" },
            "votes": { "type": "integer" },
            "locked": { "type": "boolean" }
          },
          "required": ["start_seconds", "end_seconds", "duration_seconds", "category"],
          "additionalProperties": false
        }
      },
      "sponsor_detection": {
        "type": "object",
        "description": "Detection status, methods, and epistemic caveat",
        "properties": {
          "status": { "type": "string" },
          "methods": { "type": "string" },
          "note": { "type": "string" }
        },
        "required": ["status", "methods", "note"],
        "additionalProperties": false
      }
    },
    "required": [
      "source",
      "source_url",
      "count",
      "videos"
    ],
    "additionalProperties": false
  },
