  "seo": {
    "title": "arXiv Paper Scraper Tool for Preprint Metadata",
    "description": "Search arXiv or fetch exact arXiv IDs with Better Fetch via the official arXiv Atom API, including titles, abstracts, authors, categories, publication dates, update dates, DOI values, journal references, PDF URLs, and arXiv URLs.",
    "intro": "arXiv Paper Scraper gives agents a polite, official-API path into open preprint metadata. Search by arXiv query syntax, category, title, author, or abstract text, or fetch an exact arXiv ID such as 2303.08774. The tool normalizes arXiv Atom XML into compact JSON rows with paper IDs, version labels, titles, abstracts, authors, affiliations, primary categories, all categories, publication and update timestamps, DOI values, journal references, comments, abstract URLs, and PDF URLs. It is designed for literature monitoring, AI research scouting, RAG corpus selection, academic trend tracking, reading-list generation, and research-agent workflows that need source URLs and structured paper metadata without browser scraping.",
    "useCases": [
      {
        "title": "AI research monitoring",
        "description": "Track recent papers by category or query, such as cs.CL, cs.LG, retrieval augmented generation, long context transformers, or diffusion models."
      },
      {
        "title": "Reading-list generation",
        "description": "Fetch exact arXiv IDs or bounded search results with titles, abstracts, authors, PDF links, dates, and categories for human or agent review."
      },
      {
        "title": "RAG corpus triage",
        "description": "Collect normalized preprint metadata and abstracts before deciding which papers should be downloaded, embedded, cited, or monitored."
      }
    ],
    "faqs": [
      {
        "question": "Does arXiv Paper Scraper require an API key?",
        "answer": "No. Version 0.1 uses the official public arXiv Atom API through Better Fetch. It keeps each run to a single bounded query (retrying only when arXiv returns a transient empty feed) and does not require login cookies or private credentials."
      },
      {
        "question": "Can it fetch PDFs or full paper text?",
        "answer": "No. It returns metadata, abstracts, arXiv abstract URLs, and PDF URLs. It does not download PDFs, parse TeX sources, or extract full paper bodies."
      },
      {
        "question": "Is this tool affiliated with arXiv?",
        "answer": "No. Thank you to arXiv for use of its open access interoperability. This tool was not reviewed or approved by, nor does it necessarily express or reflect the policies or opinions of, arXiv."
      }
    ],
    "keywords": [
      "arXiv scraper",
      "arXiv API",
      "arXiv metadata",
      "preprint search",
      "research papers",
      "AI papers",
      "RAG corpus",
      "academic literature"
    ]
  },
  "popularity": {
    "rank": 29,
    "score": 19
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "search",
          "id"
        ],
        "default": "search",
        "description": "Search arXiv or fetch one exact arXiv ID."
      },
      "arxiv_id": {
        "type": "string",
        "maxLength": 80,
        "description": "Exact arXiv ID or arXiv URL, e.g. 2303.08774, 2303.08774v6, or https://arxiv.org/abs/2303.08774."
      },
      "query": {
        "type": "string",
        "minLength": 2,
        "maxLength": 300,
        "description": "Raw arXiv search query using arXiv syntax, e.g. all:large language models or ti:transformer AND au:vaswani."
      },
      "title": {
        "type": "string",
        "minLength": 2,
        "maxLength": 160,
        "description": "Title text to search with the arXiv ti: field."
      },
      "author": {
        "type": "string",
        "minLength": 2,
        "maxLength": 160,
        "description": "Author name to search with the arXiv au: field."
      },
      "abstract": {
        "type": "string",
        "minLength": 2,
        "maxLength": 160,
        "description": "Abstract text to search with the arXiv abs: field."
      },
      "category": {
        "type": "string",
        "maxLength": 40,
        "description": "Optional arXiv category such as cs.CL, cs.LG, stat.ML, quant-ph, or hep-th."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 10,
        "description": "Maximum papers to return in search mode."
      },
      "start": {
        "type": "integer",
        "minimum": 0,
        "maximum": 5000,
        "default": 0,
        "description": "Zero-based arXiv result offset for search mode."
      },
      "sort_by": {
        "type": "string",
        "enum": [
          "relevance",
          "lastUpdatedDate",
          "submittedDate"
        ],
        "default": "relevance",
        "description": "arXiv sort field for search mode."
      },
      "sort_order": {
        "type": "string",
        "enum": [
          "ascending",
          "descending"
        ],
        "default": "descending",
        "description": "arXiv sort order for search mode."
      },
      "include_abstract": {
        "type": "boolean",
        "default": true,
        "description": "Include abstract/summary text when available."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "description": "Mode used for this run"
      },
      "source_url": {
        "type": "string",
        "description": "arXiv Atom API URL fetched"
      },
      "query": {
        "type": "string",
        "description": "Search query used"
      },
      "arxiv_id": {
        "type": "string",
        "description": "Exact arXiv ID used"
      },
      "count": {
        "type": "integer",
        "description": "Number of returned paper records"
      },
      "total_matches": {
        "type": "integer",
        "description": "Total arXiv matches reported by OpenSearch metadata"
      },
      "start_index": {
        "type": "integer",
        "description": "arXiv result start index"
      },
      "items_per_page": {
        "type": "integer",
        "description": "arXiv result page size"
      },
      "acknowledgement": {
        "type": "string",
        "description": "arXiv acknowledgement statement"
      },
      "papers": {
        "type": "array",
        "description": "Structured arXiv paper records",
        "items": {
          "type": "object",
          "properties": {
            "rank": {
              "type": "integer",
              "description": "Result rank in this response"
            },
            "arxiv_id": {
              "type": "string",
              "description": "arXiv identifier including version when returned"
            },
            "version": {
              "type": "string",
              "description": "arXiv version suffix, e.g. v6"
            },
            "title": {
              "type": "string",
              "description": "Paper title"
            },
            "abstract": {
              "type": "string",
              "description": "Paper abstract/summary"
            },
            "authors": {
              "type": "string",
              "description": "Comma-separated author names"
            },
            "first_author": {
              "type": "string",
              "description": "First listed author"
            },
            "last_author": {
              "type": "string",
              "description": "Last listed author"
            },
            "affiliations": {
              "type": "string",
              "description": "Comma-separated affiliations when supplied"
            },
            "primary_category": {
              "type": "string",
              "description": "Primary arXiv category"
            },
            "categories": {
              "type": "string",
              "description": "Comma-separated arXiv categories"
            },
            "published_at": {
              "type": "string",
              "description": "Initial submission timestamp"
            },
            "updated_at": {
              "type": "string",
              "description": "Latest update timestamp"
            },
            "abs_url": {
              "type": "string",
              "description": "arXiv abstract page URL"
            },
            "pdf_url": {
              "type": "string",
              "description": "arXiv PDF URL"
            },
            "doi": {
              "type": "string",
              "description": "DOI when supplied by authors"
            },
            "journal_ref": {
              "type": "string",
              "description": "Journal reference when supplied by authors"
            },
            "comment": {
              "type": "string",
              "description": "Author comment when supplied"
            }
          },
          "required": [
            "rank",
            "arxiv_id",
            "abs_url"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "mode",
      "source_url",
      "count",
      "papers",
      "acknowledgement"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "gpt4-paper",
      "input": {
        "mode": "id",
        "arxiv_id": "2303.08774"
      },
      "expect": {
        "outputMatches": {
          "papers": {
            "minLength": 1
          }
        }
      }
    },
    {
      "name": "recent-llm-search",
      "input": {
        "mode": "search",
        "query": "all:\"large language models\"",
        "category": "cs.CL",
        "max_results": 3,
        "sort_by": "submittedDate",
        "sort_order": "descending"
      },
      "expect": {
        "outputMatches": {
          "papers": {
            "minLength": 1
          }
        }
      }
    }
  ],
  "entry": "src/index.ts"
}
