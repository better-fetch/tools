  "examples": [
    {
      "name": "requests-package",
      "input": {
        "mode": "package",
        "package": "requests",
        "limit": 5,
        "max_description_chars": 500
      },
      "expect": {
        "outputMatches": {
          "package_name": "requests",
          "releases": {
            "minLength": 1
          }
        }
      }
    },
    {
      "name": "requests-release",
      "input": {
        "mode": "release",
        "package": "requests",
        "version": "2.32.5",
        "limit": 5,
        "max_description_chars": 0
      },
      "expect": {
        "outputMatches": {
          "package_name": "requests",
          "files": {
            "minLength": 1
          }
        }
      }
    },
    {
      "name": "requests-files",
      "input": {
        "mode": "files",
