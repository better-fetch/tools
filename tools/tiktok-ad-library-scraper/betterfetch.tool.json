  "seo": {
    "title": "TikTok Ad Library Search and Ad Details API",
    "description": "Search TikTok Creative Center ads and inspect source-linked public ad details, media, engagement, objectives, destinations, geography, and performance data.",
    "intro": "TikTok Ad Library Scraper reads TikTok's official Creative Center as a logged-out visitor. It captures the public data calls made by the rendered page and normalizes each result without TikTok credentials, private accounts, or synthetic records.",
    "useCases": [
      { "title": "Creative research", "description": "Review public top-ad titles, video assets, objectives, and visible performance signals by market and time period." },
      { "title": "Campaign verification", "description": "Resolve a Creative Center ad ID to its current public detail record and source URL." },
      { "title": "Landing-page intelligence", "description": "Connect public ad creative to the destination and countries TikTok exposes on the detail page." }
    ],
    "faqs": [
      { "question": "Does this require TikTok login?", "answer": "No. It reads the data TikTok's official Creative Center exposes to logged-out visitors." },
      { "question": "Is this every TikTok ad?", "answer": "No. Coverage is limited to ads TikTok publishes in Creative Center and varies by market and period." },
      { "question": "How does keyword filtering work?", "answer": "The optional query filters the current public result page by visible ad title and brand. The response marks query_applied_locally so this bounded behavior is explicit." }
    ],
    "keywords": ["TikTok Ad Library API", "TikTok Creative Center scraper", "TikTok top ads", "ad creative intelligence", "TikTok ad details"]
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "enum": ["search", "ad"], "description": "Search the public top-ads feed or inspect one ad." },
      "ad_id": { "type": "string", "pattern": "^[0-9]{8,30}$", "description": "TikTok Creative Center material ID for ad mode." },
      "region": { "type": "string", "pattern": "^[A-Za-z]{2}$", "default": "US", "description": "Two-letter market code for search mode." },
      "period": { "type": "string", "enum": ["7", "30", "180"], "default": "30", "description": "Creative Center lookback period in days." },
      "page": { "type": "integer", "minimum": 1, "maximum": 10, "default": 1, "description": "Requested public results page." },
      "query": { "type": "string", "description": "Optional case-insensitive filter applied to visible title and brand fields on the returned public page." },
      "max_results": { "type": "integer", "minimum": 1, "maximum": 20, "default": 10, "description": "Maximum normalized ads to return." }
    },
    "required": ["mode"],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "description": "Resolved operation." },
      "source_url": { "type": "string", "description": "Official Creative Center page fetched by Better Fetch." },
      "api_source_url": { "type": "string", "description": "Public TikTok data request captured from that page." },
      "count": { "type": "integer", "description": "Number of normalized ads returned." },
      "total_count": { "type": "integer", "description": "Total results TikTok reports for the selected public feed." },
      "page": { "type": "integer", "description": "Page number TikTok reports." },
      "has_more": { "type": "boolean", "description": "Whether TikTok reports another page." },
      "query_applied_locally": { "type": "boolean", "description": "True when query filtered the current public page locally." },
      "ads": {
        "type": "array",
        "description": "Normalized public Creative Center ads.",
        "items": {
          "type": "object",
          "properties": {
            "ad_id": { "type": "string", "description": "TikTok material ID." },
            "url": { "type": "string", "description": "Official public Creative Center detail URL." },
            "title": { "type": "string", "description": "Public ad title." },
            "brand_name": { "type": "string", "description": "Public brand name when present." },
            "industry_key": { "type": "string", "description": "TikTok industry label key." },
            "objective_key": { "type": "string", "description": "TikTok campaign objective key." },
            "landing_page": { "type": "string", "description": "Public campaign destination." },
            "countries_csv": { "type": "string", "description": "Comma-separated market codes TikTok exposes for the ad." },
            "source": { "type": "string", "description": "Public source label." },
            "ctr": { "type": "number", "description": "CTR value exposed by TikTok." },
            "cost": { "type": "number", "description": "Relative cost value exposed by TikTok." },
            "like_count": { "type": "number", "description": "Visible likes." },
            "comment_count": { "type": "number", "description": "Visible comments." },
            "share_count": { "type": "number", "description": "Visible shares." },
            "video_id": { "type": "string", "description": "TikTok video identifier." },
            "video_duration_seconds": { "type": "number", "description": "Video duration in seconds." },
            "video_cover_url": { "type": "string", "description": "Public video cover URL." },
            "video_url": { "type": "string", "description": "Public playable video URL." },
            "video_width": { "type": "number", "description": "Video width in pixels." },
            "video_height": { "type": "number", "description": "Video height in pixels." }
          },
          "required": ["ad_id", "url"],
          "additionalProperties": false
        }
      },
      "ad": {
        "type": "object",
        "description": "Resolved individual public ad.",
        "properties": {
          "ad_id": { "type": "string" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "brand_name": { "type": "string" },
          "industry_key": { "type": "string" },
          "objective_key": { "type": "string" },
          "landing_page": { "type": "string" },
          "countries_csv": { "type": "string" },
          "source": { "type": "string" },
          "ctr": { "type": "number" },
          "cost": { "type": "number" },
          "like_count": { "type": "number" },
          "comment_count": { "type": "number" },
          "share_count": { "type": "number" },
          "video_id": { "type": "string" },
          "video_duration_seconds": { "type": "number" },
          "video_cover_url": { "type": "string" },
          "video_url": { "type": "string" },
          "video_width": { "type": "number" },
          "video_height": { "type": "number" }
        },
        "required": ["ad_id", "url"],
        "additionalProperties": false
      }
    },
    "required": ["mode", "source_url", "api_source_url", "count", "ads"],
    "additionalProperties": false
  },
  "examples": [
    { "name": "search-top-ads", "input": { "mode": "search", "region": "AU", "period": "30", "max_results": 5 }, "expect": { "outputMatches": { "mode": "search", "ads": { "minLength": 1 } } } },
    { "name": "ad-details", "input": { "mode": "ad", "ad_id": "7644503475464159239" }, "expect": { "outputMatches": { "mode": "ad", "count": 1, "ad.ad_id": "7644503475464159239" } } }
  ],
  "entry": "src/index.ts"
}
