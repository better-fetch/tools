  "seo": {
    "title": "TikTok Scraper Tool for Public Profile Metadata",
    "description": "Scrape public TikTok profile metadata with Better Fetch, including username, display name, bio, avatar, verification, follower count, following count, likes, videos, and bio link.",
    "intro": "TikTok Scraper gives agents a dependable first step for public TikTok research. Provide a username or public profile URL and the tool renders TikTok through Better Fetch, reads the public page hydration payload, and returns normalized profile metadata without using private cookies, account credentials, or the official TikTok API.",
    "useCases": [
      {
        "title": "Creator research",
        "description": "Collect visible TikTok profile metadata for creator discovery, influencer vetting, social listening, or campaign planning workflows."
      },
      {
        "title": "Profile monitoring",
        "description": "Track public follower, following, likes, and video counts over time for profiles that matter to a brand, product, or market."
      },
      {
        "title": "Agent context",
        "description": "Let an agent inspect a public TikTok account and reason over its bio, verification, avatar, public counts, and linked website."
      }
    ],
    "faqs": [
      {
        "question": "Does TikTok Scraper need a TikTok account?",
        "answer": "No. It reads public profile pages visible to Better Fetch and does not use private TikTok cookies, passwords, API tokens, or logged-in sessions."
      },
      {
        "question": "Can it search TikTok videos by keyword or hashtag?",
        "answer": "Yes. Keyword and hashtag modes return real public TikTok video URLs from public search indexes. Coverage is best-effort and the tool never fabricates results when TikTok or an index withholds them."
      },
      {
        "question": "Why are some fields omitted for certain profiles?",
        "answer": "The tool only returns fields present in TikTok's public page payload. Private, blocked, removed, or region-limited profile data is not guessed."
      }
    ],
    "keywords": [
      "TikTok scraper",
      "TikTok profile scraper",
      "creator research",
      "social media scraper",
      "TikTok metadata",
      "public profile data"
    ]
  },
  "popularity": {
    "rank": 3,
    "score": 209000
  },
  "creditsEstimate": 2,
  "maxEngineCalls": 45,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["profile", "profile_region", "profile_videos", "following", "followers", "audience_demographics", "video", "video_transcript", "video_comments", "comment_replies", "search_suggestions", "search_users", "search_hashtag", "search_keyword", "search_top", "user_live", "live_details", "song", "song_videos", "popular_creators", "popular_hashtags", "trending_feed"],
        "description": "Public profile, relationship list, profile videos, one video, comments, or discovery operation. Inferred from video_url when omitted."
      },
      "username": {
        "type": "string",
        "description": "TikTok username, with or without the @ prefix. Use username or profile_url."
      },
      "profile_url": {
        "type": "string",
        "format": "uri",
        "description": "Public TikTok profile URL. Use username or profile_url in profile mode."
      },
      "video_url": {
        "type": "string",
        "format": "uri",
        "description": "Public TikTok video URL. Required in video mode."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 12,
        "description": "Maximum video cards or comments to return."
      },
      "comment_id": {
        "type": "string",
        "description": "Parent TikTok comment id for comment_replies mode."
      },
      "cursor": {
        "type": "integer",
        "minimum": 0,
        "description": "TikTok comment cursor or relationship min-time cursor from a previous response."
      },
      "min_time": {
        "type": "integer",
        "minimum": 0,
        "description": "TikTok relationship-list min-time cursor from a previous following or followers response."
      },
      "query": {
        "type": "string",
        "description": "Query for search_suggestions, search_users, or search_keyword mode."
      },
      "hashtag": {
        "type": "string",
        "description": "Hashtag with or without # for search_hashtag mode."
      },
      "region": {
        "type": "string",
        "description": "Two-letter region for localized search or search_suggestions mode."
      },
      "date_posted": { "type": "string", "enum": ["yesterday", "this-week", "this-month", "last-3-months", "last-6-months", "all-time"], "description": "Optional Google recency window for search_keyword." },
      "sort_by": { "type": "string", "enum": ["relevance", "most-liked", "date-posted"], "description": "Requested indexed search ordering; date-posted maps to Google's date sort." },
      "language": { "type": "string", "description": "Preferred caption language code for video_transcript mode. Defaults to en." },
      "clip_id": { "type": "string", "description": "TikTok music id for song and song_videos modes." },
      "music_url": { "type": "string", "description": "Public TikTok music URL for song and song_videos modes." }
      ,
      "room_id": { "type": "string", "description": "Optional numeric live room id to verify in live_details mode; the current room is discovered from username/profile_url when omitted." },
      "user_id": { "type": "string", "description": "Optional numeric owner id to verify in live_details mode." }
      ,
      "sample_size": { "type": "integer", "minimum": 10, "maximum": 100, "default": 50, "description": "Maximum sampled public followers for audience_demographics mode." }
    },
    "additionalProperties": false
  },
