  "seo": {
    "title": "Instagram Scraper Tool for Public Profiles and Recent Posts",
    "description": "Scrape public Instagram profile metadata and recent visible media with Better Fetch, including bio, links, avatar, follower counts, verification, captions, likes, and comments.",
    "intro": "Instagram Scraper is the broader public Instagram entry point for Better Fetch tools. Version 0.1 focuses on the reliable public web profile response: it accepts a username or profile URL, returns account metadata and counts, and includes recent visible media cards with captions, thumbnails, timestamps, likes, and comments when Instagram exposes them.",
    "useCases": [
      {
        "title": "Social research",
        "description": "Collect public Instagram profile and recent-media context for creator research, brand monitoring, social listening, or competitive analysis."
      },
      {
        "title": "Recent post summaries",
        "description": "Give an agent a bounded set of recent visible Instagram captions, post URLs, thumbnails, timestamps, likes, and comment counts for quick review."
      },
      {
        "title": "Profile monitoring",
        "description": "Track account metadata, bios, links, follower counts, and visible media counts over time without using private Instagram credentials."
      },
      {
        "title": "Story highlight research",
        "description": "List a public profile's named highlights, then extract the images, videos, timestamps, dimensions, captions, and links embedded in one highlight."
      }
    ],
    "faqs": [
      {
        "question": "Does Instagram Scraper require a login?",
        "answer": "No. It uses public Instagram web responses visible without account-specific cookies and does not use passwords, exported sessions, or private API tokens."
      },
      {
        "question": "Does this version scrape comments, hashtags, or every post?",
        "answer": "No. Version 0.1 returns public profile metadata and recent visible media cards. Comments, hashtags, locations, and deep timeline pagination should be added as separate validated slices."
      },
      {
        "question": "What happens with private profiles?",
        "answer": "Private or unavailable profile data is not bypassed. The tool returns only what Instagram exposes in the public web profile response."
      }
    ],
    "keywords": [
      "Instagram scraper",
      "Instagram profile scraper",
      "Instagram recent posts",
      "social media scraper",
      "creator research",
      "public Instagram data"
    ]
  },
  "popularity": {
    "rank": 2,
    "score": 316000
  },
  "creditsEstimate": 2,
  "maxEngineCalls": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "description": "Instagram username, with or without @. Use username or profile_url."
      },
      "profile_url": {
        "type": "string",
        "format": "uri",
        "description": "Public Instagram profile URL. Use username or profile_url."
      },
      "max_recent_posts": {
        "type": "integer",
        "minimum": 0,
        "maximum": 12,
        "default": 6,
        "description": "Maximum recent visible media cards to return"
      },
      "mode": { "type": "string", "enum": ["profile_posts", "user_reels", "audio_reels", "story_highlights", "highlight_detail", "embed", "post", "post_comments", "transcript"], "description": "Profile metadata and posts, reels, audio reels, story highlights, highlight media, one post, comments, a public video transcript, or profile embed HTML." },
      "max_results": { "type": "integer", "minimum": 1, "maximum": 100, "default": 12, "description": "Maximum visible reels, comments, highlights, or highlight items to return in the selected mode." },
      "post_url": { "type": "string", "format": "uri", "description": "Public Instagram post or reel URL for post, comments, or transcript mode." },
      "audio_id": { "type": "string", "description": "Numeric id from an instagram.com/reels/audio/{audio_id}/ page for audio_reels mode." },
      "highlight_id": { "type": "string", "description": "Numeric Instagram highlight id or full highlight URL for highlight_detail mode." },
      "language": { "type": "string", "pattern": "^[A-Za-z]{2,8}$", "description": "Optional spoken-language hint for transcript mode; omit for detection." }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "description": "Resolved operation mode" },
      "count": { "type": "integer", "description": "Number of public comments returned" },
      "next_cursor": { "type": "string", "description": "Cursor for another public comment page when exposed" },
      "has_more": { "type": "boolean", "description": "Whether Instagram reports another public comment page" },
      "transcript": {
        "type": "object",
        "description": "Speech transcript generated from the public video rendition.",
        "properties": {
          "text": { "type": "string", "description": "Normalized spoken text." },
          "language": { "type": "string", "description": "Detected or requested language code." },
          "language_probability": { "type": "number", "description": "Language-detection confidence when available." },
          "duration_seconds": { "type": "number", "description": "Media duration in seconds." }
        },
        "required": ["text"],
        "additionalProperties": false
      },
      "transcript_segments": {
        "type": "array",
        "description": "Timed transcript segments.",
        "items": {
          "type": "object",
          "properties": {
            "start": { "type": "number" },
            "end": { "type": "number" },
            "text": { "type": "string" }
          },
          "required": ["start", "end", "text"],
          "additionalProperties": false
        }
      },
      "audio_id": { "type": "string", "description": "Instagram audio id" },
      "audio_title": { "type": "string", "description": "Visible audio title" },
      "audio_artist": { "type": "string", "description": "Visible audio artist" },
      "audio_reel_count_text": { "type": "string", "description": "Instagram's visible total reel count for the audio" },
      "highlight_id": { "type": "string", "description": "Instagram story highlight id" },
      "highlight_title": { "type": "string", "description": "Visible story highlight title" },
      "source_url": {
        "type": "string",
        "description": "Public Instagram profile URL"
      },
      "username": {
        "type": "string",
        "description": "Instagram username"
      },
      "full_name": {
        "type": "string",
        "description": "Visible profile name"
      },
      "biography": {
        "type": "string",
        "description": "Profile biography"
      },
      "external_url": {
        "type": "string",
        "description": "Primary external URL"
      },
      "profile_pic_url": {
        "type": "string",
        "description": "Profile picture URL"
      },
      "verified": {
        "type": "boolean",
        "description": "Whether the profile is verified"
      },
      "private_account": {
        "type": "boolean",
        "description": "Whether the profile is private"
      },
      "follower_count": {
        "type": "integer",
        "description": "Visible follower count"
      },
      "following_count": {
        "type": "integer",
        "description": "Visible following count"
      },
      "media_count": {
        "type": "integer",
        "description": "Visible post/media count"
      },
      "recent_posts": {
        "type": "array",
        "description": "Recent visible media cards",
        "items": {
          "type": "object",
          "properties": {
            "shortcode": {
              "type": "string",
              "description": "Instagram shortcode"
            },
            "url": {
              "type": "string",
              "description": "Instagram post URL"
            },
            "caption": {
              "type": "string",
              "description": "Visible caption"
            },
            "thumbnail": {
              "type": "string",
              "description": "Display media URL"
            },
            "is_video": {
              "type": "boolean",
              "description": "Whether the media is video"
            },
            "taken_at": {
              "type": "string",
              "description": "ISO timestamp"
            },
            "like_count": {
              "type": "integer",
              "description": "Visible like count"
            },
            "comment_count": {
              "type": "integer",
              "description": "Visible comment count"
            }
          },
          "required": [
            "shortcode",
            "url"
          ],
          "additionalProperties": false
        }
      },
      "reels": {
        "type": "array",
        "description": "Visible public reel cards from the profile reels tab",
        "items": {
          "type": "object",
          "properties": {
            "shortcode": { "type": "string", "description": "Instagram reel shortcode" },
            "url": { "type": "string", "description": "Canonical public reel URL" },
            "thumbnail": { "type": "string", "description": "Visible reel thumbnail URL" },
            "video_url": { "type": "string", "description": "Public reel video URL when Instagram exposes it" },
            "caption": { "type": "string", "description": "Visible reel caption" },
            "taken_at": { "type": "string", "description": "ISO publication timestamp" },
            "view_count": { "type": "integer", "description": "Visible abbreviated view count expanded to an integer" },
            "like_count": { "type": "integer", "description": "Visible abbreviated like count expanded to an integer" },
            "comment_count": { "type": "integer", "description": "Visible abbreviated comment count expanded to an integer" },
            "author_id": { "type": "string", "description": "Reel author id" },
            "author_username": { "type": "string", "description": "Reel author username" },
            "author_name": { "type": "string", "description": "Reel author display name" },
            "author_verified": { "type": "boolean", "description": "Whether the reel author is verified" }
          },
          "required": ["shortcode", "url"],
          "additionalProperties": false
        }
      },
      "embed_html": { "type": "string", "description": "Raw public Instagram profile embed HTML" },
      "post": {
        "type": "object",
        "description": "One normalized public Instagram post or reel",
        "properties": {
          "id": { "type": "string", "description": "Instagram media id" },
          "shortcode": { "type": "string", "description": "Instagram media shortcode" },
          "url": { "type": "string", "description": "Canonical public media URL" },
          "type": { "type": "string", "description": "Instagram media or product type" },
          "caption": { "type": "string", "description": "Visible caption text" },
          "accessibility_caption": { "type": "string", "description": "Instagram accessibility description" },
          "thumbnail": { "type": "string", "description": "Display image URL" },
          "video_url": { "type": "string", "description": "Public video URL when exposed" },
          "video_duration": { "type": "number", "description": "Video duration in seconds" },
          "has_audio": { "type": "boolean", "description": "Whether the video has audio" },
          "view_count": { "type": "integer", "description": "Visible video view count" },
          "play_count": { "type": "integer", "description": "Visible video play count" },
          "like_count": { "type": "integer", "description": "Visible like count" },
          "comment_count": { "type": "integer", "description": "Visible comment count" },
          "taken_at": { "type": "string", "description": "ISO media publication timestamp" },
          "author_id": { "type": "string", "description": "Author account id" },
          "author_username": { "type": "string", "description": "Author username" },
          "author_name": { "type": "string", "description": "Author display name" },
          "author_avatar": { "type": "string", "description": "Author profile image URL" }
        },
        "required": ["id", "shortcode", "url"],
        "additionalProperties": false
      },
      "comments": {
        "type": "array",
