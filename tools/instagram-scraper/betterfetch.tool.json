            "taken_at": { "type": "string", "description": "ISO publication timestamp" },
            "expires_at": { "type": "string", "description": "ISO source expiration timestamp when exposed" },
            "image_url": { "type": "string", "description": "Highest-priority public image or poster URL" },
            "video_url": { "type": "string", "description": "Public video rendition URL when exposed" },
            "width": { "type": "integer", "description": "Original media width" },
            "height": { "type": "integer", "description": "Original media height" },
            "duration": { "type": "number", "description": "Video duration in seconds" },
            "has_audio": { "type": "boolean", "description": "Whether the video has audio" },
            "accessibility_caption": { "type": "string", "description": "Instagram accessibility description" },
