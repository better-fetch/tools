    },
    {
      "name": "openai-public-reel",
      "input": { "mode": "post", "post_url": "https://www.instagram.com/openai/reel/DawRXxVMil6/" },
      "expect": { "outputMatches": { "mode": "post", "username": "openai" } }
    },
    {
      "name": "openai-public-comments",
      "input": { "mode": "post_comments", "post_url": "https://www.instagram.com/openai/reel/DawRXxVMil6/", "max_results": 20 },
      "expect": { "outputMatches": { "mode": "post_comments", "comments": { "minLength": 1 } } }
    },
    {
      "name": "openai-public-reel-transcript",
      "input": { "mode": "transcript", "post_url": "https://www.instagram.com/openai/reel/DawRXxVMil6/", "language": "en" },
      "expect": { "outputMatches": { "mode": "transcript" } }
    }
