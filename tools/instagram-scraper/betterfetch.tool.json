            "id": { "type": "string", "description": "Instagram comment id" },
            "text": { "type": "string", "description": "Comment text" },
            "created_at": { "type": "string", "description": "ISO comment creation timestamp" },
            "like_count": { "type": "integer", "description": "Visible comment like count" },
            "reply_count": { "type": "integer", "description": "Visible child comment count" },
            "author_id": { "type": "string", "description": "Comment author id" },
            "author_username": { "type": "string", "description": "Comment author username" },
            "author_avatar": { "type": "string", "description": "Comment author profile image URL" },
            "author_verified": { "type": "boolean", "description": "Whether the comment author is verified" }
          },
          "required": ["id", "text"],
          "additionalProperties": false
        }
      },
      "highlights": {
        "type": "array",
        "description": "Public story highlights visible on the profile",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "description": "Instagram highlight id" },
            "title": { "type": "string", "description": "Visible highlight title" },
