  "seo": {
    "title": "Instagram Scraper Tool for Public Profiles and Recent Posts",
    "description": "Scrape public Instagram profile metadata and recent visible media with Better Fetch, including bio, links, avatar, follower counts, verification, captions, likes, and comments.",
    "intro": "Instagram Scraper is the broader public Instagram entry point for Better Fetch tools. Version 0.1 focuses on the reliable public web profile response: it accepts a username or profile URL, returns account metadata and counts, and includes recent visible media cards with captions, thumbnails, timestamps, likes, and comments when Instagram exposes them.",
    "useCases": [
      {
        "title": "Social research",
        "description": "Collect public Instagram profile and recent-media context for creator research, brand monitoring, social listening, or competitive analysis."
      },
      {
        "title": "Recent post summaries",
        "description": "Give an agent a bounded set of recent visible Instagram captions, post URLs, thumbnails, timestamps, likes, and comment counts for quick review."
      },
      {
        "title": "Profile monitoring",
        "description": "Track account metadata, bios, links, follower counts, and visible media counts over time without using private Instagram credentials."
      }
    ],
    "faqs": [
      {
        "question": "Does Instagram Scraper require a login?",
        "answer": "No. It uses public Instagram web responses visible without account-specific cookies and does not use passwords, exported sessions, or private API tokens."
      },
      {
        "question": "Does this version scrape comments, hashtags, or every post?",
        "answer": "No. Version 0.1 returns public profile metadata and recent visible media cards. Comments, hashtags, locations, and deep timeline pagination should be added as separate validated slices."
      },
      {
        "question": "What happens with private profiles?",
        "answer": "Private or unavailable profile data is not bypassed. The tool returns only what Instagram exposes in the public web profile response."
      }
    ],
    "keywords": [
      "Instagram scraper",
      "Instagram profile scraper",
      "Instagram recent posts",
      "social media scraper",
      "creator research",
      "public Instagram data"
    ]
  },
  "popularity": {
    "rank": 2,
    "score": 316000
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "username": {
        "type": "string",
        "description": "Instagram username, with or without @. Use username or profile_url."
      },
      "profile_url": {
        "type": "string",
        "format": "uri",
        "description": "Public Instagram profile URL. Use username or profile_url."
      },
      "max_recent_posts": {
        "type": "integer",
        "minimum": 0,
        "maximum": 12,
        "default": 6,
        "description": "Maximum recent visible media cards to return"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "source_url": {
        "type": "string",
        "description": "Public Instagram profile URL"
      },
      "username": {
        "type": "string",
        "description": "Instagram username"
      },
      "full_name": {
        "type": "string",
        "description": "Visible profile name"
      },
      "biography": {
        "type": "string",
        "description": "Profile biography"
      },
      "external_url": {
        "type": "string",
        "description": "Primary external URL"
      },
      "profile_pic_url": {
        "type": "string",
        "description": "Profile picture URL"
      },
      "verified": {
        "type": "boolean",
        "description": "Whether the profile is verified"
      },
      "private_account": {
        "type": "boolean",
        "description": "Whether the profile is private"
      },
      "follower_count": {
        "type": "integer",
        "description": "Visible follower count"
      },
      "following_count": {
        "type": "integer",
        "description": "Visible following count"
      },
      "media_count": {
        "type": "integer",
        "description": "Visible post/media count"
      },
      "recent_posts": {
        "type": "array",
        "description": "Recent visible media cards",
        "items": {
          "type": "object",
          "properties": {
            "shortcode": {
              "type": "string",
              "description": "Instagram shortcode"
            },
            "url": {
              "type": "string",
              "description": "Instagram post URL"
            },
            "caption": {
              "type": "string",
              "description": "Visible caption"
            },
            "thumbnail": {
              "type": "string",
              "description": "Display media URL"
            },
            "is_video": {
              "type": "boolean",
              "description": "Whether the media is video"
            },
            "taken_at": {
              "type": "string",
              "description": "ISO timestamp"
            },
            "like_count": {
              "type": "integer",
              "description": "Visible like count"
            },
            "comment_count": {
              "type": "integer",
              "description": "Visible comment count"
            }
          },
          "required": [
            "shortcode",
            "url"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "source_url",
      "username",
      "full_name"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "openai-profile",
      "input": {
        "username": "openai",
        "max_recent_posts": 3
      },
      "expect": {
        "outputMatches": {
          "username": "openai",
          "full_name": "OpenAI"
        }
      }
    }
  ],
