  "seo": {
    "title": "Hugging Face Models Scraper Tool for Model Discovery and AI Market Research",
    "description": "Search Hugging Face Hub models or fetch exact model metadata with Better Fetch, including model ID, author, task, library, downloads, likes, license, tags, timestamps, URLs, and files.",
    "intro": "Hugging Face Models Scraper gives agents a structured route into public Hugging Face Hub model metadata. Search models by keyword and sort by downloads, likes, created date, update time, or trending score, or fetch one exact model repo by ID or URL. The tool normalizes model IDs, authors, Hub URLs, pipeline tasks, library names, license hints, download counts, likes, public/private and gated labels, tags, created and last-modified timestamps, and sibling filenames. It is designed for AI model discovery, LLM ecosystem monitoring, open-source competitive research, model catalog enrichment, leaderboard preparation, DevRel research, and RAG-ready AI tooling inventories.",
    "useCases": [
      {
        "title": "Model discovery",
        "description": "Search the Hugging Face Hub by keyword and rank public models by downloads, likes, freshness, or trending score."
      },
      {
        "title": "AI ecosystem monitoring",
        "description": "Track popular model families, tasks, libraries, tags, and license hints for research, DevRel, and competitive intelligence workflows."
      },
      {
        "title": "Agent catalog enrichment",
        "description": "Fetch exact model metadata and filenames before deciding which model card, weights, or repository files an agent should inspect next."
      }
    ],
    "faqs": [
      {
        "question": "Does Hugging Face Models Scraper require a Hugging Face token?",
        "answer": "No. Version 0.1 uses public Hugging Face Hub API endpoints and only returns public metadata visible without account-specific access."
      },
      {
        "question": "Does it download model weights?",
        "answer": "No. It returns metadata and public sibling filenames. It does not download model files, bypass gated repositories, or access private models."
      },
      {
        "question": "Is this tool affiliated with Hugging Face?",
        "answer": "No. Better Fetch is not affiliated with or endorsed by Hugging Face. The logo mark is used only to identify the public target service."
      }
    ],
    "keywords": [
      "Hugging Face scraper",
      "Hugging Face models API",
      "AI model discovery",
      "LLM model metadata",
      "model downloads",
      "model likes",
      "Hugging Face Hub",
      "open source models"
    ]
  },
  "popularity": {
    "rank": 39,
    "score": 28
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "search",
          "details"
        ],
        "default": "search",
        "description": "search = search public Hub models; details = fetch one exact model repo."
      },
      "query": {
        "type": "string",
        "description": "Search query for search mode, such as llama, bert, diffusion, or sentence-transformers."
      },
      "model_id": {
        "type": "string",
        "description": "Model ID or Hugging Face model URL for details mode, such as bert-base-uncased or meta-llama/Llama-3.1-8B-Instruct."
      },
      "sort": {
        "type": "string",
        "enum": [
          "downloads",
          "likes",
          "lastModified",
          "createdAt",
          "trendingScore"
        ],
        "default": "downloads",
        "description": "Sort field for search mode."
      },
      "direction": {
        "type": "string",
        "enum": [
          "desc",
          "asc",
          "-1",
          "1"
        ],
        "default": "desc",
        "description": "Sort direction for search mode."
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10,
        "description": "Maximum model rows to return."
      }
    },
    "additionalProperties": false
  },
