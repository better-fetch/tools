    "sourceUrl": "https://commons.wikimedia.org/wiki/File:Y_Combinator_logo.svg"
  },
  "seo": {
    "title": "Hacker News Scraper Tool for Stories, Comments, and Users",
    "description": "Search Hacker News stories and comments with Better Fetch, inspect item threads, and fetch public HN user metadata through the Algolia and Firebase APIs.",
    "intro": "Hacker News Scraper gives agents a clean, validated path into the public HN discussion graph without scraping fragile HTML. Search by keyword and tag, sort by relevance or date, inspect a story or comment thread, or fetch public user metadata. The tool normalizes HN Algolia and Firebase API responses into compact records for trend monitoring, launch research, technical sentiment, DevRel workflows, and competitive intelligence.",
    "useCases": [
      {
        "title": "Launch and competitor monitoring",
        "description": "Track mentions of a company, product, domain, or technology across Hacker News stories and comments with author, points, comment count, and timestamp fields."
      },
      {
        "title": "Show HN and Ask HN research",
        "description": "Use tag filters such as show_hn, ask_hn, front_page, story, and comment to focus on launches, questions, or live front-page discussion."
      },
      {
        "title": "Thread inspection",
        "description": "Fetch a known HN item and return the story plus a bounded set of nested comments so agents can summarize discussion without crawling page HTML."
      }
    ],
    "faqs": [
      {
        "question": "Does Hacker News Scraper require a login or API key?",
        "answer": "No. Version 0.1 uses the public HN Algolia API and the official Hacker News Firebase API through Better Fetch. It does not access saved items or private account data."
      },
      {
        "question": "Can it export every historical HN comment?",
        "answer": "Not yet. Version 0.1 is intentionally bounded: search returns up to 50 records and item mode returns a limited comment slice. Full archive export and deep pagination should be separate validated slices."
      },
      {
        "question": "Which tag filters can I use?",
        "answer": "The tags input is passed to HN Algolia after validation. Common filters include story, comment, front_page, ask_hn, show_hn, job, author_username, and story_itemid."
      }
    ],
    "keywords": [
      "Hacker News scraper",
      "HN Algolia API",
      "Hacker News search",
      "HN comments",
      "Show HN monitoring",
      "Ask HN research",
      "AI agent news tool"
    ]
  },
  "popularity": {
    "rank": 25,
    "score": 173
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "search",
          "item",
          "user"
        ],
        "default": "search",
        "description": "Run an Algolia search, inspect an HN item/thread, or fetch public HN user metadata."
      },
      "query": {
        "type": "string",
        "description": "Search query for stories or comments. Optional when using tags such as front_page."
      },
      "tags": {
        "type": "string",
        "default": "story",
        "description": "HN Algolia tags separated by commas, spaces, or semicolons, such as story, comment, front_page, ask_hn, show_hn, job, author_pg, or story_8863."
      },
      "sort": {
        "type": "string",
        "enum": [
          "relevance",
          "date"
        ],
        "default": "relevance",
        "description": "Search ordering: relevance or date."
      },
      "item_id": {
        "type": "integer",
        "minimum": 1,
        "description": "Hacker News item ID for item mode."
      },
      "username": {
        "type": "string",
        "description": "Hacker News username for user mode."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10,
        "description": "Maximum search records to return."
      },
      "max_comments": {
        "type": "integer",
        "minimum": 0,
        "maximum": 50,
        "default": 10,
        "description": "Maximum nested comments returned in item mode."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "description": "Mode used for the run"
      },
      "source_url": {
        "type": "string",
        "description": "Fetched HN API URL"
      },
      "count": {
        "type": "integer",
        "description": "Number of primary records returned"
      },
      "total_matches": {
        "type": "integer",
        "description": "Total Algolia matches when reported"
      },
      "records": {
        "type": "array",
        "description": "Hacker News story, comment, or item records",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "description": "Record type"
            },
            "object_id": {
              "type": "string",
              "description": "HN or Algolia object ID"
            },
            "title": {
              "type": "string",
              "description": "Story or item title"
            },
            "url": {
              "type": "string",
              "description": "External story URL when present"
            },
            "hn_url": {
              "type": "string",
              "description": "Hacker News item URL"
            },
            "author": {
              "type": "string",
              "description": "HN username"
            },
            "points": {
              "type": "integer",
              "description": "Story points"
            },
            "num_comments": {
              "type": "integer",
              "description": "Comment count"
            },
            "created_at": {
              "type": "string",
              "description": "Creation timestamp"
            },
            "tags": {
              "type": "string",
              "description": "Comma-separated Algolia tags"
            },
            "story_id": {
              "type": "integer",
              "description": "Parent story ID for comment records"
            },
            "parent_id": {
              "type": "integer",
              "description": "Parent item ID for comment records"
            },
            "text": {
              "type": "string",
              "description": "Story/comment text with HTML removed"
            }
          },
          "required": [
            "type",
            "object_id"
          ],
          "additionalProperties": false
        }
      },
      "comments": {
        "type": "array",
        "description": "Bounded nested comment records for item mode",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "description": "Record type"
            },
            "object_id": {
              "type": "string",
              "description": "HN comment ID"
            },
            "parent_id": {
              "type": "integer",
              "description": "Parent item ID"
            },
            "author": {
              "type": "string",
              "description": "HN username"
            },
            "created_at": {
              "type": "string",
              "description": "Comment timestamp"
            },
            "level": {
              "type": "integer",
              "description": "Nested comment depth"
            },
            "text": {
              "type": "string",
              "description": "Comment text with HTML removed"
            }
          },
          "required": [
            "type",
            "object_id"
          ],
          "additionalProperties": false
        }
      },
      "user": {
        "type": "object",
        "description": "Public HN user metadata",
        "properties": {
          "type": {
            "type": "string",
            "description": "Record type"
          },
          "username": {
            "type": "string",
            "description": "HN username"
          },
          "karma": {
            "type": "integer",
            "description": "HN karma"
          },
          "created_at": {
            "type": "string",
            "description": "User creation timestamp"
          },
          "about_text": {
            "type": "string",
            "description": "About text with HTML removed"
          },
          "submitted_count": {
            "type": "integer",
            "description": "Number of submitted public items"
          },
          "recent_submitted_ids": {
            "type": "string",
            "description": "Comma-separated recent submitted item IDs"
          }
        },
        "required": [
          "type",
          "username"
        ],
        "additionalProperties": false
      }
    },
    "required": [
      "mode",
      "source_url",
      "count"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "openai-stories",
      "input": {
        "mode": "search",
        "query": "openai",
        "tags": "story",
        "max_results": 3
      },
      "expect": {
        "outputMatches": {
          "records": {
            "minLength": 1
          }
        }
      }
    }
  ],
  "entry": "src/index.ts"
}
