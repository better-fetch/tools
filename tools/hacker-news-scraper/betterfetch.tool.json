{
  "name": "hacker_news_scraper",
  "version": "0.1.1",
  "title": "Hacker News Scraper",
  "description": "Search Hacker News stories and comments, inspect item threads, or fetch public user metadata through the HN Algolia and Firebase APIs, returning titles, URLs, authors, points, comments, timestamps, tags, text, and profile fields.",
  "category": "news",
  "logo": {
    "label": "Hacker News logo",
