  "seo": {
    "title": "Google Play Reviews Scraper Tool for App Feedback",
    "description": "Extract visible Google Play review cards with Better Fetch, including reviewer names, ratings, dates, body text, helpful counts, review IDs, and source URLs.",
    "intro": "Google Play Reviews Scraper gives agents a validated first slice of Android app feedback. Provide a package name or Google Play URL and the tool fetches the public app detail page, extracts the visible review cards, and normalizes reviewer names, ratings, dates, body text, helpful counts, review IDs, avatars, and the source app URL.",
    "useCases": [
      {
        "title": "App feedback snapshots",
        "description": "Pull the visible Google Play review cards for a product or competitor before sending an analyst or agent into deeper sentiment work."
      },
      {
        "title": "Release monitoring",
        "description": "Capture current public review snippets, star ratings, dates, and helpful counts after a major Android app release."
      },
      {
        "title": "Support triage",
        "description": "Give customer support or product agents structured examples of recent visible complaints and praise without hand-copying store text."
      }
    ],
    "faqs": [
      {
        "question": "Does Google Play Reviews Scraper paginate every review?",
        "answer": "No. Version 0.1 extracts the review cards visible in the public app page HTML. Full pagination and advanced filtering should be built as later validated slices."
      },
      {
        "question": "Can I pass a Google Play URL instead of an app ID?",
        "answer": "Yes. The tool accepts a package ID such as com.openai.chatgpt or a Google Play details URL containing an id parameter."
      },
      {
        "question": "Does this require a Google account or API key?",
        "answer": "No. The tool reads public Google Play app pages through Better Fetch and does not use account-specific Google credentials."
      }
    ],
    "keywords": [
      "Google Play reviews scraper",
      "Android app reviews",
      "Google Play feedback",
      "app store reviews",
      "mobile app sentiment",
      "AI agent app research"
    ]
  },
  "popularity": {
    "rank": 20,
    "score": 1500
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "app_id_or_url": {
        "type": "string",
        "minLength": 1,
        "description": "Google Play app package ID or details URL containing an id parameter."
      },
      "language": {
        "type": "string",
        "default": "en-US",
        "description": "Google Play hl parameter, such as en-US or de-DE."
      },
      "country": {
        "type": "string",
        "default": "US",
        "description": "Google Play gl parameter, such as US, AU, GB, or DE."
      },
      "max_reviews": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10,
        "default": 5,
        "description": "Maximum visible review cards to return."
      }
    },
    "required": [
      "app_id_or_url"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "app_id": {
        "type": "string",
        "description": "Google Play app package ID"
      },
      "app_title": {
        "type": "string",
        "description": "Visible Google Play app title"
      },
      "developer": {
        "type": "string",
        "description": "Visible developer or author name"
      },
      "rating": {
        "type": "number",
        "description": "Aggregate star rating when present"
      },
      "rating_count": {
        "type": "integer",
        "description": "Aggregate rating count when present"
      },
      "source_url": {
        "type": "string",
        "description": "Fetched Google Play details URL"
      },
      "count": {
        "type": "integer",
        "description": "Number of review cards returned"
      },
      "reviews": {
        "type": "array",
        "description": "Visible Google Play review cards",
        "items": {
          "type": "object",
          "properties": {
            "review_id": {
              "type": "string",
              "description": "Google Play review ID"
            },
            "reviewer": {
              "type": "string",
              "description": "Visible reviewer name"
            },
            "rating": {
              "type": "integer",
              "description": "Star rating from 1 to 5"
            },
            "date": {
              "type": "string",
              "description": "Visible review date label"
            },
            "body": {
              "type": "string",
              "description": "Visible review body text"
            },
            "helpful_count": {
              "type": "integer",
              "description": "Helpful vote count when shown"
            },
            "user_image": {
              "type": "string",
              "description": "Reviewer avatar URL when shown"
            }
          },
          "required": [
            "review_id"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "app_id",
      "source_url",
      "count",
      "reviews"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "chatgpt-visible-reviews",
      "input": {
        "app_id_or_url": "com.openai.chatgpt",
        "max_reviews": 2
      },
      "expect": {
        "outputMatches": {
          "reviews": {
            "minLength": 1
          }
        }
      }
    }
  ],
  "entry": "src/index.ts"
}
