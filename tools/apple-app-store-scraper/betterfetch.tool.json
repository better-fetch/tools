  "seo": {
    "title": "Apple App Store Scraper Tool for iOS App Metadata",
    "description": "Search Apple App Store apps with Better Fetch and return iOS app IDs, bundle IDs, titles, developers, genres, ratings, prices, icons, versions, descriptions, and URLs.",
    "intro": "Apple App Store Scraper gives agents a reliable first slice of iOS app intelligence. Provide a keyword query or Apple track ID and the tool calls Apple's public iTunes Search API, normalizing App Store app IDs, bundle IDs, titles, developers, genres, ratings, rating counts, prices, currencies, icons, versions, release dates, descriptions, and store URLs.",
    "useCases": [
      {
        "title": "iOS market research",
        "description": "Search a product category or competitor name and capture structured App Store metadata for comparable iPhone and iPad apps."
      },
      {
        "title": "ASO discovery",
        "description": "Collect app names, genres, ratings, descriptions, icons, and App Store URLs before deeper keyword, review, or publisher analysis."
      },
      {
        "title": "Agent briefs",
        "description": "Give an agent normalized Apple App Store context for a brand, category, or known app ID without custom API glue."
      }
    ],
    "faqs": [
      {
        "question": "Does Apple App Store Scraper extract reviews?",
        "answer": "No. Version 0.1 returns app search and lookup metadata. Customer reviews, top charts, privacy labels, and publisher catalogs should be separate validated slices."
      },
      {
        "question": "Can I look up a specific app ID?",
        "answer": "Yes. Pass app_id with an Apple track ID, such as 6448311069 for ChatGPT, and the tool uses Apple's lookup endpoint."
      },
      {
        "question": "Does it require an Apple API key?",
        "answer": "No. The tool uses Apple's public iTunes Search API through Better Fetch and does not require account-specific Apple credentials."
      }
    ],
    "keywords": [
      "Apple App Store scraper",
      "iOS app metadata",
      "iTunes Search API",
      "App Store search",
      "ASO research",
      "AI agent app research"
    ]
  },
  "popularity": {
    "rank": 22,
    "score": 1000
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Apple App Store keyword search query. Used when app_id is not provided."
      },
      "app_id": {
        "type": "string",
        "description": "Apple track ID for lookup mode, such as 6448311069."
      },
      "country": {
        "type": "string",
        "default": "US",
        "description": "Two-letter App Store country code, such as US, AU, GB, or DE."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10,
        "description": "Maximum App Store apps to return for search mode."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "description": "search or lookup"
      },
      "query": {
        "type": "string",
        "description": "Requested keyword query when in search mode"
      },
      "app_id": {
        "type": "string",
        "description": "Requested Apple track ID when in lookup mode"
      },
      "country": {
        "type": "string",
        "description": "Requested App Store country"
      },
      "source_url": {
        "type": "string",
        "description": "Fetched iTunes Search API URL"
      },
      "count": {
        "type": "integer",
        "description": "Number of apps returned"
      },
      "apps": {
        "type": "array",
        "description": "Apple App Store app metadata rows",
        "items": {
          "type": "object",
          "properties": {
            "app_id": {
              "type": "string",
              "description": "Apple track ID"
            },
            "bundle_id": {
              "type": "string",
              "description": "iOS bundle identifier"
            },
            "title": {
              "type": "string",
              "description": "App title"
            },
            "developer": {
              "type": "string",
              "description": "Visible seller or developer name"
            },
            "genre": {
              "type": "string",
              "description": "Primary genre"
            },
            "genres": {
              "type": "string",
              "description": "Comma-separated genre labels"
            },
            "rating": {
              "type": "number",
              "description": "Average user rating"
            },
            "rating_count": {
              "type": "integer",
              "description": "User rating count"
            },
            "price": {
              "type": "number",
              "description": "App price"
            },
            "currency": {
              "type": "string",
              "description": "Price currency"
            },
            "url": {
              "type": "string",
              "description": "App Store URL"
            },
            "icon": {
              "type": "string",
              "description": "Artwork or icon URL"
            },
            "version": {
              "type": "string",
              "description": "Current app version"
            },
            "release_date": {
              "type": "string",
              "description": "Original release date"
            },
            "updated_at": {
              "type": "string",
              "description": "Current version release date"
            },
            "description": {
              "type": "string",
              "description": "App description"
            }
          },
          "required": [
            "app_id",
            "title",
            "url"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "mode",
      "country",
      "source_url",
      "count",
      "apps"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
