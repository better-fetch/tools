  "seo": {
    "title": "PubMed Search Scraper Tool for Biomedical Literature",
    "description": "Search PubMed with Better Fetch via NCBI E-utilities and return PMIDs, titles, authors, journals, publication dates, DOI values, abstracts, MeSH terms, publication types, and article URLs.",
    "intro": "PubMed Search Scraper gives agents a reliable public-API path into biomedical literature. Provide a PubMed query such as cancer immunotherapy[Title/Abstract], CRISPR[Title], or machine learning radiology and the tool calls NCBI ESearch, ESummary, and EFetch through Better Fetch. It returns compact citation rows with PMIDs, titles, PubMed URLs, authors, journal names, publication dates, DOI values, publication types, abstracts when available, MeSH descriptor terms, languages, volume, issue, and pages. It is built for literature monitoring, biomedical RAG ingestion, systematic-review screening, pharma intelligence, clinical evidence queues, and academic discovery workflows.",
    "useCases": [
      {
        "title": "Literature monitoring",
        "description": "Run precise PubMed queries with date filters and collect recent paper metadata for disease, drug, biomarker, clinical-trial, or research-topic monitoring."
      },
      {
        "title": "Review screening",
        "description": "Create compact screening tables with PMID, title, authors, journal, publication type, DOI, abstract, and PubMed URL before deeper human or agent review."
      },
      {
        "title": "Biomedical RAG ingestion",
        "description": "Collect PubMed abstracts, MeSH terms, and citation metadata in a structured shape suitable for downstream embeddings, retrieval, and evidence synthesis."
      }
    ],
    "faqs": [
      {
        "question": "Does PubMed Search Scraper require an API key?",
        "answer": "No. Version 0.1 uses the public NCBI E-utilities endpoints through Better Fetch. It keeps each run small and does not require login cookies, browser automation, or a private NCBI API key."
      },
      {
        "question": "Does it download full-text articles?",
        "answer": "No. It returns PubMed citation metadata and abstracts available in PubMed XML. It does not bypass publisher paywalls or fetch full-text article bodies."
      },
      {
        "question": "Can I use PubMed field tags and date filters?",
        "answer": "Yes. The query field accepts normal PubMed syntax, and the tool supports optional min_date, max_date, date_type, article_type, and journal filters for bounded searches."
      }
    ],
    "keywords": [
      "PubMed scraper",
      "PubMed API",
      "NCBI E-utilities",
      "biomedical literature",
      "medical research",
      "MeSH terms",
      "systematic review",
      "AI biomedical RAG"
    ]
  },
  "popularity": {
    "rank": 28,
    "score": 2
  },
  "creditsEstimate": 2,
  "maxEngineCalls": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "minLength": 2,
        "maxLength": 300,
        "description": "PubMed query using normal PubMed syntax, e.g. cancer immunotherapy or CRISPR[Title]."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 10,
        "description": "Maximum PubMed records to return."
      },
      "sort": {
        "type": "string",
        "enum": [
          "relevance",
          "pub_date"
        ],
        "default": "relevance",
        "description": "Result ordering: relevance or PubMed publication date."
      },
      "min_date": {
        "type": "string",
        "description": "Optional PubMed date lower bound in YYYY, YYYY/MM, or YYYY/MM/DD format."
      },
      "max_date": {
        "type": "string",
        "description": "Optional PubMed date upper bound in YYYY, YYYY/MM, or YYYY/MM/DD format."
      },
      "date_type": {
        "type": "string",
        "enum": [
          "pdat",
          "edat"
        ],
        "default": "pdat",
        "description": "Date field used for min_date and max_date: publication date or Entrez date."
      },
      "article_type": {
        "type": "string",
        "maxLength": 80,
        "description": "Optional PubMed publication type filter, e.g. Review or Clinical Trial."
      },
      "journal": {
        "type": "string",
        "maxLength": 120,
        "description": "Optional journal filter, e.g. Nature Medicine."
      },
      "include_abstracts": {
        "type": "boolean",
        "default": true,
        "description": "Fetch PubMed XML and include abstracts when available."
      },
      "include_mesh_terms": {
        "type": "boolean",
        "default": true,
        "description": "Fetch PubMed XML and include MeSH descriptor terms when available."
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Normalized PubMed query used"
      },
      "source_url": {
        "type": "string",
        "description": "NCBI ESearch URL fetched first"
      },
      "count": {
        "type": "integer",
        "description": "Number of returned article records"
      },
      "total_matches": {
        "type": "integer",
        "description": "Total PubMed matches reported by ESearch"
      },
      "articles": {
        "type": "array",
        "description": "Structured PubMed article records",
        "items": {
          "type": "object",
          "properties": {
            "rank": {
              "type": "integer",
              "description": "Result rank in this response"
            },
            "pmid": {
              "type": "string",
              "description": "PubMed identifier"
            },
            "title": {
              "type": "string",
              "description": "Article title"
            },
            "article_url": {
              "type": "string",
              "description": "PubMed article URL"
            },
            "journal": {
              "type": "string",
              "description": "Journal abbreviation or title"
            },
            "full_journal_name": {
              "type": "string",
              "description": "Full journal name when available"
            },
            "pub_date": {
              "type": "string",
              "description": "Publication date label"
            },
            "epub_date": {
              "type": "string",
              "description": "Electronic publication date label"
            },
            "authors": {
              "type": "string",
              "description": "Comma-separated author names"
            },
            "first_author": {
              "type": "string",
              "description": "First listed author"
            },
            "last_author": {
              "type": "string",
              "description": "Last listed author"
            },
            "doi": {
              "type": "string",
              "description": "Digital Object Identifier when available"
            },
            "publication_types": {
              "type": "string",
              "description": "Comma-separated publication types"
            },
            "language": {
              "type": "string",
              "description": "Comma-separated language codes"
            },
            "source": {
              "type": "string",
              "description": "PubMed source abbreviation"
            },
            "volume": {
              "type": "string",
              "description": "Journal volume"
            },
            "issue": {
              "type": "string",
              "description": "Journal issue"
            },
            "pages": {
              "type": "string",
              "description": "Pagination"
            },
            "abstract": {
              "type": "string",
              "description": "Abstract text when requested and available"
            },
            "mesh_terms": {
              "type": "string",
              "description": "Comma-separated MeSH descriptor terms when requested and available"
            },
            "keywords": {
              "type": "string",
              "description": "Comma-separated author keywords when present in PubMed XML"
            }
          },
          "required": [
            "rank",
            "pmid",
            "article_url"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "query",
      "source_url",
      "count",
      "articles"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "cancer-immunotherapy",
      "input": {
