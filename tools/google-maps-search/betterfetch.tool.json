  "seo": {
    "title": "Google Maps Search Scraper Tool for Local Leads",
    "description": "Search Google Maps and return structured local business leads with names, addresses, ratings, review counts, categories, phones, websites, and coordinates.",
    "intro": "Google Maps Search gives agents and sales workflows a practical local-lead primitive. Provide a natural-language place query, such as coffee roasters in Sydney, and the tool renders Google Maps through Better Fetch before returning structured places that are ready for enrichment, CRM import, or follow-up research.",
    "useCases": [
      {
        "title": "Local lead lists",
        "description": "Build targeted prospect lists from Google Maps searches with business names, addresses, categories, phone numbers, websites, ratings, and review counts."
      },
      {
        "title": "Market mapping",
        "description": "Compare local business density, review quality, and category coverage across suburbs, cities, or regions without hand-copying Maps results."
      }
    ],
    "faqs": [
      {
        "question": "What fields does Google Maps Search return?",
        "answer": "The tool returns place names and, when visible in the rendered results, address, rating, review count, category, phone, website, latitude, and longitude."
      },
      {
        "question": "Do I need a Google Maps API key?",
        "answer": "No. This tool uses Better Fetch's browser engine to render the public Google Maps search page and parse the result cards into structured output."
      }
    ],
    "keywords": [
      "google maps scraper",
      "local lead scraper",
      "business leads",
      "maps search API",
      "local SEO data"
    ]
  },
  "popularity": {
    "rank": 1,
    "score": 489000
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 3,
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "minLength": 2,
        "maxLength": 256,
        "description": "What and where, e.g. \"coffee roasters in Sydney\""
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 40,
        "default": 10,
        "description": "Max places to return"
      }
    },
    "required": [
      "query"
    ],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "The query as searched"
      },
      "places": {
        "type": "array",
        "description": "Places in result order",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Place name"
            },
            "address": {
              "type": "string",
              "description": "Street address"
            },
            "rating": {
              "type": "number",
              "description": "Average rating (1–5)"
            },
            "reviews": {
              "type": "integer",
              "description": "Review count"
            },
            "category": {
              "type": "string",
              "description": "Primary category"
            },
            "phone": {
              "type": "string",
              "description": "Phone number, when listed"
            },
            "website": {
              "type": "string",
              "description": "Website URL, when listed"
            },
            "lat": {
              "type": "number",
              "description": "Latitude"
            },
            "lng": {
              "type": "number",
              "description": "Longitude"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        }
      },
      "count": {
        "type": "integer",
        "description": "Number of places returned"
      }
    },
    "required": [
      "query",
      "places",
      "count"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "sydney-coffee",
      "input": {
        "query": "coffee roasters in Sydney",
        "max_results": 5
      },
      "expect": {
        "outputMatches": {
          "places": {
            "minLength": 1
          }
        }
      }
    }
  ],
  "entry": "src/index.ts"
}
