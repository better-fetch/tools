{
  "name": "pinterest_scraper",
  "version": "0.2.0",
  "title": "Pinterest Scraper",
  "description": "Search public Pinterest pins, inspect pin metadata, list a user's public boards, or return a public board's pins.",
  "category": "social",
  "logo": {
    "label": "Pinterest logo",
    "svg": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\"><circle cx=\"32\" cy=\"32\" r=\"32\" fill=\"#E60023\"/><path fill=\"#fff\" d=\"M32 10.5c-11.9 0-21.5 8.6-21.5 19.8 0 8.3 4.7 13 11.5 15.3-.2-1.4-.3-3.7.1-5.3l2.8-11.7s-.7-1.5-.7-3.7c0-3.5 2-6.1 4.6-6.1 2.2 0 3.2 1.6 3.2 3.6 0 2.2-1.4 5.4-2.1 8.4-.6 2.5 1.3 4.6 3.8 4.6 4.6 0 8.1-4.8 8.1-11.8 0-6.2-4.4-10.5-10.8-10.5-7.4 0-11.7 5.5-11.7 11.2 0 2.2.9 4.6 1.9 5.9.2.3.2.5.1.8l-.7 2.7c-.2.9-.8 1.1-1.7.7-6.3-2.9-10.2-12-10.2-19.3C8.7 18.6 17.8 4 34.7 4 48.3 4 59 13.7 59 26.7c0 13.5-8.5 24.4-20.3 24.4-4 0-7.7-2.1-9-4.5l-2.4 9.3c-.9 3.4-3.3 7.7-4.9 10.3 3.7 1.1 7.6 1.7 11.6 1.7C51.7 67.9 66 53.6 66 36 66 18.3 51.7 4 34 4c-.7 0-1.3 0-2 .1Z\"/></svg>",
    "sourceUrl": "https://www.pinterest.com/"
  },
  "seo": {
    "title": "Pinterest Search, Pin, and Board Scraper API",
    "description": "Search Pinterest and retrieve public pin metadata, user boards, and board pin listings as normalized JSON.",
    "intro": "Pinterest Scraper unifies four public Pinterest retrieval surfaces in one tool. Search mode renders public pin results, pin mode uses Pinterest's official oEmbed endpoint, and user_boards or board mode parse Pinterest's public server-rendered pages.",
    "useCases": [
      { "title": "Visual research", "description": "Search public pins or resolve a pin URL into a clean title, image, creator, and canonical URL." },
      { "title": "Creator intelligence", "description": "List the public boards exposed on a Pinterest creator profile." },
      { "title": "Board monitoring", "description": "Return normalized public pin cards and visible board metadata from a board URL." }
    ],
    "faqs": [
      { "question": "Does this require a Pinterest account?", "answer": "No. All four modes use public Pinterest surfaces." },
      { "question": "What does search return?", "answer": "Search returns the public pin id, title, canonical pin URL, and visible thumbnail for each rendered result." },
      { "question": "Can it access private boards?", "answer": "No. Only boards and pins visible on public Pinterest pages are supported." }
    ],
    "keywords": ["Pinterest scraper", "Pinterest search API", "Pinterest pin API", "Pinterest boards API", "Pinterest oEmbed"]
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "enum": ["pin", "search", "user_boards", "board"], "description": "Capability to run. Defaults to pin for backward compatibility." },
      "pin_url": { "type": "string", "format": "uri", "description": "Public Pinterest pin URL." },
      "url": { "type": "string", "format": "uri", "description": "Public pin, profile, or board URL depending on mode." },
      "query": { "type": "string", "description": "Search query for search mode." },
      "handle": { "type": "string", "description": "Pinterest profile handle for user_boards mode." },
      "max_results": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string" },
      "source_url": { "type": "string" },
      "title": { "type": "string" },
      "handle": { "type": "string" },
      "pin_url": { "type": "string" },
      "author_name": { "type": "string" },
      "author_url": { "type": "string" },
      "thumbnail_url": { "type": "string" },
      "thumbnail_width": { "type": "integer" },
      "thumbnail_height": { "type": "integer" },
      "embed_html": { "type": "string" },
      "width": { "type": "integer" },
      "height": { "type": "integer" },
      "pin_count": { "type": "integer" },
      "count": { "type": "integer" },
      "pins": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "url": { "type": "string" },
            "thumbnail_url": { "type": "string" }
          },
          "required": ["id", "title", "url"],
          "additionalProperties": false
        }
      },
      "boards": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string" },
            "thumbnail_url": { "type": "string" }
          },
          "required": ["title", "url"],
          "additionalProperties": false
        }
      }
    },
    "required": ["mode", "source_url"],
    "additionalProperties": false
  },
  "examples": [
    { "name": "pinterest-pin", "input": { "mode": "pin", "pin_url": "https://www.pinterest.com/pin/99360735500167749/" }, "expect": { "outputMatches": { "mode": "pin", "title": "Love my Pinterest t-shirt!" } } },
    { "name": "pinterest-search", "input": { "mode": "search", "query": "Italian Pot Roast", "max_results": 10 }, "expect": { "outputMatches": { "mode": "search" } } },
    { "name": "pinterest-user-boards", "input": { "mode": "user_boards", "handle": "broadstbullycom", "max_results": 10 }, "expect": { "outputMatches": { "mode": "user_boards", "handle": "broadstbullycom" } } },
    { "name": "pinterest-board", "input": { "mode": "board", "url": "https://www.pinterest.com/lizmrodgers/moms-night/", "max_results": 10 }, "expect": { "outputMatches": { "mode": "board" } } }
  ],
  "entry": "src/index.ts"
}
