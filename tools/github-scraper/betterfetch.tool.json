{
  "name": "github_scraper",
  "version": "0.1.1",
  "title": "GitHub Scraper",
  "description": "Extract public GitHub repository, profile, repository search, and trending repository metadata, including stars, forks, topics, languages, licenses, dates, follower counts, and trend velocity when visible.",
  "category": "developer-tools",
