    "sourceUrl": "https://icon-sets.iconify.design/logos/github-icon/"
  },
  "seo": {
    "title": "GitHub Scraper API for Users, Repositories, Activity, and Trending",
    "description": "Scrape public GitHub users, repos, pull requests, events, followers, following, contributions, search, and trending data with Better Fetch.",
    "intro": "GitHub Scraper gives agents a structured view of public open-source activity without requiring a GitHub token. Eleven modes cover user profiles, owned repositories, public pull requests, activity events, social graphs, contribution summaries, repository details, repository search, and both GitHub Trending surfaces.",
    "useCases": [
      {
        "title": "Open-source momentum checks",
        "description": "Fetch stars, forks, languages, topics, licenses, and update dates for a repository before an agent compares project health or adoption."
      },
      {
        "title": "Developer and organization research",
        "description": "Read public profile fields such as bio, company, location, follower count, website, and public repo count for sourcing or partner research."
      },
      {
        "title": "Trend discovery",
        "description": "Pull GitHub Trending repositories by language and period or search repositories by keyword, sorted by stars, forks, or update date."
      }
    ],
    "faqs": [
      {
        "question": "Does GitHub Scraper need a GitHub token?",
        "answer": "No. Version 0.1 uses public GitHub endpoints and public pages through Better Fetch. It does not access private repositories or authenticated account data."
      },
      {
        "question": "Can it fetch pull requests and public activity?",
        "answer": "Yes. Pull-request mode searches public pull requests authored by a user, while activity mode returns their recent public GitHub events. Separate first-party tools cover repository issues and releases."
      },
      {
        "question": "Why are results limited?",
        "answer": "The unauthenticated GitHub API is rate-limited, and GitHub Trending has a bounded page size. The tool keeps each run small and predictable so it remains reliable for agent workflows."
      }
    ],
    "keywords": [
      "GitHub scraper",
      "GitHub repository metadata",
      "GitHub profile scraper",
      "GitHub Trending scraper",
      "open source intelligence",
      "developer tools scraper",
      "AI agent GitHub research"
    ]
  },
  "popularity": {
    "rank": 23,
    "score": 45
  },
  "creditsEstimate": 1,
  "maxEngineCalls": 1,
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "repo",
          "profile",
          "repositories",
          "pull_requests",
          "activity",
          "followers",
          "following",
          "contributions",
          "search",
          "trending",
          "trending_developers"
        ],
        "default": "repo",
        "description": "GitHub operation to run. User-scoped modes use username_or_url; repo uses repo_or_url."
      },
      "repo_or_url": {
        "type": "string",
        "description": "Owner/repo slug or GitHub repository URL. Required for repo mode."
      },
      "username_or_url": {
        "type": "string",
        "description": "GitHub username or profile URL. Required for profile, repositories, pull_requests, activity, followers, following, and contributions modes."
      },
      "query": {
        "type": "string",
        "description": "GitHub repository search query. Required for search mode."
      },
      "language": {
        "type": "string",
        "description": "Optional GitHub Trending language filter, such as typescript, python, go, or rust."
      },
      "since": {
        "type": "string",
        "enum": [
          "daily",
          "weekly",
          "monthly"
        ],
        "default": "daily",
        "description": "GitHub Trending period for trending mode."
      },
      "sort": {
        "type": "string",
        "enum": [
          "stars",
          "forks",
          "updated"
        ],
        "default": "stars",
        "description": "Repository search sort field."
      },
      "order": {
        "type": "string",
        "enum": [
          "desc",
          "asc"
        ],
        "default": "desc",
        "description": "Repository search sort direction."
      },
      "max_results": {
        "type": "integer",
        "minimum": 1,
        "maximum": 25,
        "default": 10,
        "description": "Maximum records to return for list modes."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "description": "Extraction mode used"
      },
      "source_url": {
        "type": "string",
        "description": "Fetched GitHub API or page URL"
      },
      "count": {
        "type": "integer",
        "description": "Number of returned records"
      },
      "items": {
        "type": "array",
        "description": "Public GitHub repository, profile, search, or trending records",
        "items": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "description": "Record type"
            },
            "name": {
              "type": "string",
              "description": "Repository name or display name"
            },
            "full_name": {
              "type": "string",
              "description": "Repository owner/name"
            },
            "owner": {
              "type": "string",
              "description": "Repository owner login"
            },
            "username": {
              "type": "string",
              "description": "GitHub username for profile records"
            },
            "url": {
              "type": "string",
              "description": "Public GitHub URL"
            },
            "description": {
              "type": "string",
              "description": "Repository description"
            },
            "homepage_url": {
              "type": "string",
              "description": "Repository homepage URL"
            },
            "language": {
              "type": "string",
              "description": "Primary repository language"
            },
            "stars": {
              "type": "integer",
              "description": "Repository star count"
            },
            "stars_today": {
              "type": "integer",
              "description": "Stars gained in the selected Trending period when visible"
            },
            "forks": {
              "type": "integer",
              "description": "Repository fork count"
            },
            "watchers": {
              "type": "integer",
              "description": "Repository watcher count"
            },
            "open_issues": {
              "type": "integer",
              "description": "Open issue count"
            },
            "topics": {
              "type": "string",
              "description": "Comma-separated repository topics"
            },
            "license": {
              "type": "string",
              "description": "Repository license label"
            },
            "is_archived": {
              "type": "boolean",
              "description": "Whether the repository is archived"
            },
            "is_fork": {
              "type": "boolean",
              "description": "Whether the repository is a fork"
            },
            "default_branch": {
              "type": "string",
              "description": "Default branch name"
            },
            "created_at": {
              "type": "string",
              "description": "Creation timestamp"
            },
            "updated_at": {
              "type": "string",
              "description": "Last update timestamp"
            },
            "pushed_at": {
              "type": "string",
              "description": "Last push timestamp"
            },
            "size_kb": {
              "type": "integer",
              "description": "Repository size in KB"
            },
            "bio": {
              "type": "string",
              "description": "Public profile bio"
            },
            "company": {
              "type": "string",
              "description": "Public profile company"
            },
            "location": {
              "type": "string",
              "description": "Public profile location"
            },
            "blog": {
              "type": "string",
              "description": "Public profile website"
            },
            "twitter_username": {
              "type": "string",
              "description": "Public X/Twitter username"
            },
            "followers": {
              "type": "integer",
              "description": "Follower count"
            },
            "following": {
              "type": "integer",
              "description": "Following count"
            },
            "public_repos": {
              "type": "integer",
              "description": "Public repository count"
            },
            "avatar_url": {
              "type": "string",
              "description": "Profile avatar URL"
            },
            "repository": {
              "type": "string",
              "description": "Related owner/repository slug"
            },
            "state": {
              "type": "string",
              "description": "Pull request state"
            },
            "event_type": {
              "type": "string",
              "description": "GitHub public event type"
            },
            "number": {
              "type": "integer",
              "description": "Pull request number"
            },
            "comments": {
              "type": "integer",
              "description": "Pull request comment count"
            },
            "contributions": {
              "type": "integer",
              "description": "Visible contribution total for the rendered period"
            },
            "contribution_days": {
              "type": "integer",
              "description": "Days with one or more visible contributions"
            },
            "max_contribution_level": {
              "type": "integer",
              "description": "Highest visible contribution intensity level"
            },
            "first_date": {
              "type": "string",
              "description": "First date in the contribution graph"
            },
            "last_date": {
              "type": "string",
              "description": "Last date in the contribution graph"
            },
            "popular_repository": {
              "type": "string",
              "description": "Repository highlighted for a trending developer"
            },
            "popular_repository_url": {
              "type": "string",
              "description": "Public URL of the highlighted repository"
            },
            "closed_at": {
              "type": "string",
              "description": "Pull request close timestamp"
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "mode",
      "source_url",
      "count",
      "items"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "react-repo",
      "input": {
        "mode": "repo",
        "repo_or_url": "facebook/react"
      },
      "expect": {
        "outputMatches": {
          "items": {
            "minLength": 1
          }
        }
      }
    },
    {
      "name": "openai-profile",
      "input": { "mode": "profile", "username_or_url": "openai" },
      "expect": { "outputMatches": { "mode": "profile", "items": { "minLength": 1 } } }
    },
    {
      "name": "openai-repositories",
      "input": { "mode": "repositories", "username_or_url": "sindresorhus", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "repositories", "items": { "minLength": 1 } } }
    },
    {
      "name": "openai-pull-requests",
      "input": { "mode": "pull_requests", "username_or_url": "sindresorhus", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "pull_requests", "items": { "minLength": 1 } } }
    },
    {
      "name": "openai-activity",
      "input": { "mode": "activity", "username_or_url": "sindresorhus", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "activity", "items": { "minLength": 1 } } }
    },
    {
      "name": "openai-followers",
      "input": { "mode": "followers", "username_or_url": "sindresorhus", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "followers", "items": { "minLength": 1 } } }
    },
    {
      "name": "openai-following",
      "input": { "mode": "following", "username_or_url": "sindresorhus", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "following", "items": { "minLength": 1 } } }
    },
    {
      "name": "openai-contributions",
      "input": { "mode": "contributions", "username_or_url": "sindresorhus" },
      "expect": { "outputMatches": { "mode": "contributions", "count": 1 } }
    },
    {
      "name": "trending-repositories",
      "input": { "mode": "trending", "since": "daily", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "trending", "items": { "minLength": 1 } } }
    },
    {
      "name": "trending-developers",
      "input": { "mode": "trending_developers", "since": "daily", "max_results": 3 },
      "expect": { "outputMatches": { "mode": "trending_developers", "items": { "minLength": 1 } } }
    }
  ],
  "entry": "src/index.ts"
}
