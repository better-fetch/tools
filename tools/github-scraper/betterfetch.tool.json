{
  "name": "github_scraper",
  "version": "0.2.0",
  "title": "GitHub Scraper",
  "description": "Extract public GitHub users, repositories, pull requests, activity, followers, following, contributions, repository details, search, trending repositories, and trending developers as normalized JSON.",
  "category": "developer-tools",
