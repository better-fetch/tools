  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": [
          "date_range",
          "doi"
        ],
        "default": "date_range",
        "description": "Fetch preprints by date window or fetch one exact preprint DOI."
      },
      "server": {
        "type": "string",
        "enum": [
          "biorxiv",
          "medrxiv"
        ],
        "default": "biorxiv",
        "description": "Preprint server to query."
      },
      "doi": {
        "type": "string",
        "maxLength": 140,
        "description": "Exact preprint DOI for DOI mode, e.g. 10.1101/2024.05.28.596311."
      },
      "date_from": {
        "type": "string",
        "maxLength": 10,
        "description": "Start date in YYYY-MM-DD format for date_range mode."
      },
      "date_to": {
        "type": "string",
        "maxLength": 10,
        "description": "End date in YYYY-MM-DD format for date_range mode."
      },
      "cursor": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100000,
        "default": 0,
        "description": "bioRxiv API cursor/start offset for a date window."
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 30,
        "default": 10,
        "description": "Maximum records to return from this single API response."
      },
      "category": {
        "type": "string",
        "maxLength": 80,
        "description": "Optional category filter such as neuroscience, cell_biology, or sports_medicine."
      },
      "include_abstract": {
        "type": "boolean",
        "default": true,
        "description": "Include abstract text when returned by the public API."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "description": "Mode used for this run"
      },
      "source_url": {
        "type": "string",
        "description": "bioRxiv API URL fetched"
      },
      "server": {
        "type": "string",
        "description": "Server queried"
      },
      "doi": {
        "type": "string",
        "description": "Exact DOI used"
      },
      "date_from": {
        "type": "string",
        "description": "Start date used"
      },
      "date_to": {
        "type": "string",
        "description": "End date used"
      },
      "cursor": {
        "type": "integer",
        "description": "Cursor/start offset used"
      },
      "count": {
        "type": "integer",
        "description": "Number of returned preprints"
      },
      "total_matches": {
        "type": "integer",
        "description": "Total API matches reported for the interval"
      },
      "new_papers_count": {
        "type": "integer",
        "description": "New paper count reported for the interval"
      },
      "status": {
        "type": "string",
        "description": "API status message"
      },
      "preprints": {
        "type": "array",
        "description": "Normalized bioRxiv or medRxiv preprint records",
        "items": {
          "type": "object",
          "properties": {
            "rank": {
              "type": "integer",
              "description": "Result rank in this response"
            },
            "doi": {
              "type": "string",
              "description": "Preprint DOI"
            },
            "server": {
              "type": "string",
              "description": "bioRxiv or medRxiv server label"
            },
            "title": {
              "type": "string",
              "description": "Preprint title"
            },
            "authors": {
              "type": "string",
              "description": "Author string returned by the API"
            },
            "date": {
              "type": "string",
              "description": "Posted date"
            },
            "version": {
              "type": "string",
              "description": "Preprint version"
            },
            "type": {
              "type": "string",
              "description": "Manuscript type"
            },
            "license": {
              "type": "string",
              "description": "License code"
            },
            "category": {
              "type": "string",
              "description": "Subject category"
            },
            "abstract": {
              "type": "string",
              "description": "Abstract text"
            },
            "author_corresponding": {
              "type": "string",
              "description": "Corresponding author"
            },
            "author_corresponding_institution": {
              "type": "string",
              "description": "Corresponding author institution"
            },
            "funder": {
              "type": "string",
              "description": "Funder label when returned"
            },
            "published_doi": {
              "type": "string",
              "description": "Published article DOI when linked"
            },
            "preprint_url": {
              "type": "string",
              "description": "Preprint landing URL"
            },
            "pdf_url": {
              "type": "string",
              "description": "Derived PDF URL"
            },
            "jatsxml_url": {
              "type": "string",
              "description": "JATS XML URL"
            }
          },
          "required": [
            "rank",
            "doi"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "mode",
      "source_url",
      "server",
      "count",
      "preprints"
    ],
    "additionalProperties": false
  },
  "examples": [
    {
      "name": "biorxiv-neuroscience-window",
      "input": {
        "mode": "date_range",
        "server": "biorxiv",
        "date_from": "2024-06-01",
        "date_to": "2024-06-03",
        "limit": 2,
        "include_abstract": false
      },
      "expect": {
        "outputMatches": {
          "preprints": {
            "minLength": 1
          }
        }
      }
    },
    {
      "name": "biorxiv-doi",
      "input": {
        "mode": "doi",
        "server": "biorxiv",
        "doi": "10.1101/2024.05.28.596311",
        "include_abstract": false
      },
      "expect": {
        "outputMatches": {
          "preprints": {
            "minLength": 1
          }
        }
      }
    }
  ],
  "entry": "src/index.ts"
}
